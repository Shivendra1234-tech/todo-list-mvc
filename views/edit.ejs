<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Page</title>
</head>
<body>
  <h1>Edit the Task</h1>
  <form action="/update" method="POST">
    <input type="text" name="task" value="<%= task.title %>">
    <input type="hidden" name="id" value="<%= task._id %>">
    <button>Save</button>
  </form>
</body>
</html>